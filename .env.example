# =============================================================================
# DER3 — Single configuration file. Change values here when moving servers.
# Copy this file to .env and edit values below.
# =============================================================================

# ---- Backend API (server.js) ----
# Port the Node API server listens on
API_PORT=4000

# ---- SQL Server connection ----
DB_USER=
DB_PASSWORD=
DB_SERVER=localhost
DB_DATABASE=Der3
DB_PORT=1433

# 32-byte hex key used to encrypt uploaded files in the FileBlob table.
# IMPORTANT: When moving servers, copy the EXACT SAME value across — otherwise
# previously-uploaded files cannot be decrypted.
FILE_ENCRYPTION_KEY=

# ---- Frontend (Vite) ----
# Public origin of the backend API as seen by the browser.
# Example values:
#   http://localhost:4000        (local dev)
#   http://192.168.1.50:4000     (LAN deploy)
#   https://api.example.com      (production)
VITE_API_URL=http://localhost:4000

# ---- Optional ----
# Gemini AI key (if AI features are used)
GEMINI_API_KEY=
